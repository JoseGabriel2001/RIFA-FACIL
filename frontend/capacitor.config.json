{
  "appId": "com.rifafacil.app",
  "appName": "RifaFacil",
  "webDir": "build",
  "bundledWebRuntime": false,
  "server": {
    "url": "https://spin-raffle.preview.emergentagent.com",
    "cleartext": true
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor": "#f97316",
      "showSpinner": true,
      "spinnerColor": "#ffffff"
    },
    "StatusBar": {
      "style": "light",
      "backgroundColor": "#f97316"
    },
    "Keyboard": {
      "resize": "body",
      "resizeOnFullScreen": true
    }
  },
  "ios": {
    "scheme": "RifaFacil",
    "contentInset": "automatic"
  },
  "android": {
    "allowMixedContent": true
  }
}
